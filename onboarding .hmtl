/* =====================================
   AI ASSISTANT BRAIN
===================================== */

const AssistantBrain = {

  intro(){
    return t("Hi! I’m here to guide you 👋");
  },

  stepIntro(step){
    if(step === 0) return t("Let's start by getting to know you.");
    if(step === 1) return t("Tell me about your goals so I can guide you.");
    if(step === 2) return t("Almost done! Choose the account type that fits you.");
  },

  fieldPrompt(field){

    const prompts = {

      text: [
        () => `${t("Tell me your")} ${t(field.label).toLowerCase()}.`,
        () => `${t("Enter your")} ${t(field.label).toLowerCase()}.`
      ],

      email: [
        () => t("We’ll use this to contact you."),
        () => t("Enter a valid email so we can reach you.")
      ],

      select: [
        () => t("Choose the option that matches you best."),
        () => t("Pick the path that feels right for you.")
      ],

      checkbox: [
        () => t("You can select multiple skills."),
        () => t("Choose the skills you want to grow.")
      ]

    };

    const options = prompts[field.type] || [() => t("Fill in this field.")];

    return options[Math.floor(Math.random() * options.length)]();
  },

  suggestion(data){

    if(!data.skills) return "";

    if(data.skills.includes("Design"))
      return t("💡 You could become a creative designer.");

    if(data.skills.includes("Programming"))
      return t("💡 AI development could be a great path for you.");

    if(data.skills.includes("Video Editing"))
      return t("💡 Video creators are in huge demand.");

    return "";
  }

};
let lastAssistantMessage = "";

function updateAssistant(field){

  let message = "";

  if(!field) return;

  const reactions = {

    name: "Nice to meet you! What should we call you? 😊",

    email: "We'll use this email to send your membership details.",

    country: "Which country are you joining from? ARMY is everywhere 🌎",

    army_since: "When did your BTS journey begin? 💜",

    favorite_member: "Choose your BTS bias. This is always a tough choice!",

  };

  message = reactions[field.id] || `Let's continue with ${field.label.toLowerCase()}.`;

  if(message === lastAssistantMessage) return;

  lastAssistantMessage = message;

  typeAssistant(message);

}




let assistantTypingInterval = null;

function typeAssistant(text){

  const assistant = document.querySelector(".assistant");
  const bubble = document.getElementById("assistantText");
  const dots = document.getElementById("typingDots");

  // 🧠 Stop any previous typing
  if(assistantTypingInterval){
    clearInterval(assistantTypingInterval);
    assistantTypingInterval = null;
  }

  assistant.classList.add("talking");

  bubble.textContent = "";
  dots.style.display = "inline";

  let i = 0;

  assistantTypingInterval = setInterval(()=>{

    bubble.textContent += text[i];
    i++;

    if(i >= text.length){

      clearInterval(assistantTypingInterval);
      assistantTypingInterval = null;

      dots.style.display = "none";
      assistant.classList.remove("talking");

    }

  },30);

}

// TRANSLATE FUNCTION
function t(label){
  return translations[language][label] || label;
}






const meta ={

    card:{
      cardId:"bts_global_army_invite",
      type:"membership_invite"
    },

    token:{
      value:"INV-8F9D3A1"
    },

    membership:{
      inviteType:"community_membership",
      approvalRequired:true,
      accessPolicy:{durationDays:7}
    },

    processing:{
      createProfile:true,
      createSupportTicket:true,
      routeDepartment:"membership"
    },

    onboarding:{
      engine:"alita",
      flowId:"bts_global_army_invite",
      language:"en"
    },

    system:{
      source:"alita_iframe",
      submittedAt:"2026-03-16T14:00:00Z"
    }
  }


function buildSubmissionMeta(){

  return {

    card: meta.card,

    token: meta.token,

    membership: meta.membership,

    processing: meta.processing,

    invite: meta.invite,

    onboarding:{
      engine:"alita",
      flowId: meta.card.cardId,
      language: language || "en",
      version:"1.0"
    },

    system:{
      source:"alita_iframe",
      submittedAt:new Date().toISOString(),
      userAgent:navigator.userAgent
    }

  };

}



// FINAL SUBMIT WITH GREEN CHECK AND RETURNED DATA
// FINAL SUBMIT WITH SUCCESS + ERROR HANDLING


function submitProfile() {
  const payload = {};

  // Collect form fields safely
  flow.forEach(f => {
    const key = f.database || f.id;
    payload[key] = data[f.id] !== undefined ? data[f.id] : null;
  });

  // Attach meta safely
  if (typeof meta === "object" && meta !== null) {
    payload.meta = buildSubmissionMeta();
  }

  console.log("Submitting payload:", payload);

  function handleResponse(event) {
    console.log("Message received from parent:", event.data);

    if (event.data?.type === "multiPhaseSubmitResponse") {
      const response = event.data.data || {};
      const isSuccess = event.data.success !== false && response.success !== false;

      window.removeEventListener("message", handleResponse);

      if (isSuccess) {
        let summaryHTML = "<ul>";

        for (const key in response) {
          if (response[key] !== null && response[key] !== undefined && key !== "meta") {
            const value = Array.isArray(response[key]) ? response[key].join(", ") : response[key];
            summaryHTML += `<li><strong>${t(key)}:</strong> ${value}</li>`;
          }
        }

        if (response.meta) {
          summaryHTML += `
            <li>
              <strong>Card Meta:</strong>
              <button class="toggleMetaBtn">Show / Hide</button>
              <pre class="metaContent">${JSON.stringify(response.meta, null, 2)}</pre>
            </li>
          `;
        }

        document.getElementById("content").innerHTML = `
          <div class="successScreen">
            <svg class="checkmark" viewBox="0 0 52 52">
              <circle class="checkmark__circle" cx="26" cy="26" r="25" fill="none"/>
              <path class="checkmark__check" fill="none" d="M14 27l7 7 16-16"/>
            </svg>
            <p>${t("Submission successful!")}</p>
            ${summaryHTML}
          </div>
        `;
        alitaSpeak("success");

        // Add toggle functionality
        document.querySelectorAll(".toggleMetaBtn").forEach(btn => {
          const content = btn.nextElementSibling;
          btn.addEventListener("click", () => content.classList.toggle("show"));
        });

        localStorage.removeItem("multiPhaseData");
        launchConfetti();
      } else {
        const errorMessage = response.error || t("Submission failed. Please try again.");
        document.getElementById("content").innerHTML = `
          <div class="errorScreen">
            <svg class="errorIcon" viewBox="0 0 52 52">
              <circle cx="26" cy="26" r="25" fill="none" stroke="#e74c3c" stroke-width="4"/>
              <line x1="16" y1="16" x2="36" y2="36" stroke="#e74c3c" stroke-width="4"/>
              <line x1="36" y1="16" x2="16" y2="36" stroke="#e74c3c" stroke-width="4"/>
            </svg>
            <p style="color:#e74c3c;">${errorMessage}</p>
            <button onclick="location.reload()" class="retryBtn">${t("Try Again")}</button>
          </div>
        `;
      }
    }
  }
  alitaSpeak("error");

  window.addEventListener("message", handleResponse);

  // Show spinner immediately
  document.getElementById("content").innerHTML = `
    <div class="successScreen">
      <div class="spinner"></div>
      <p>${t("Submitting your data...")}</p>
    </div>`;
    alitaSpeak("submit");

  // Post payload exactly as parent expects
  window.parent.postMessage({ type: "multiPhaseSubmit", data: payload }, "*");
}


/* =====================================
   DOM READY
===================================== */
document.addEventListener("DOMContentLoaded", () => {

  initializeAlita();

});


</script>



